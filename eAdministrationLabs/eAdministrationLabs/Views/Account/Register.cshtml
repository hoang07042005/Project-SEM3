@model eAdministrationLabs.Models.ViewModels.RegisterViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <!-- Card Register -->
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-dark text-white text-center p-4 rounded-top">
                    <h4 class="font-weight-bold mb-0">Register</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Register" method="post">
                        <!-- Full Name -->
                        <div class="mb-4">
                            <label asp-for="FullName" class="form-label font-weight-bold text-dark">Full Name</label>
                            <input asp-for="FullName" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Enter your full name" required />
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label font-weight-bold text-dark">Email Address</label>
                            <input asp-for="Email" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Enter your email" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label font-weight-bold text-dark">Password</label>
                            <input asp-for="Password" type="password" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Enter your password" required />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label font-weight-bold text-dark">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg rounded-3 border-0 shadow-sm" placeholder="Confirm your password" required />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- Select Roles -->
                        <div class="d-flex align-items-center mb-4">
                            <label class="form-label mb-0 me-3 text-dark font-weight-bold">Select Roles:</label>
                            <div class="d-flex flex-wrap align-items-center gap-3">
                                @foreach (var role in ViewBag.Roles)
                                {
                                    if (role.RoleName == "students")
                                    {
                                        <div class="form-check form-check-inline">
                                            <input type="checkbox" name="SelectedRoleIds" value="@role.Id" class="form-check-input" checked />
                                            <label class="form-check-label">@role.RoleName</label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Submit Button -->
                        <div class="d-grid mb-4">
                            <button type="submit" class="btn btn-dark btn-lg rounded-3 shadow-sm">
                                Register <i class="fas fa-user-plus ml-2"></i>
                            </button>
                        </div>
                    </form>

                    <!-- Login Link -->
                    <p class="mt-3 text-center">
                        Already have an account? <a asp-action="Login" class="text-dark font-weight-bold text-decoration-none hover-link">Login here</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add FontAwesome for Icons -->
<script src="https://kit.fontawesome.com/a076d05399.js"></script>

<!-- Custom CSS for Link Hover Effect -->
<style>
    .hover-link:hover {
        color: #007bff;
        text-decoration: underline;
    }
</style>
