@model IEnumerable<eAdministrationLabs.Models.LabUsageLog>

@{
    ViewData["Title"] = "Lab Usage Log";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Tiêu đề trang -->
<div class="container mt-5">
    <h1 class="text-center text-success font-weight-bold mb-4" style="font-size: 2.5rem;">Lab Usage Log</h1>

    <!-- Nút Create New -->
    <div class="text-center mb-4">
        <a asp-action="Create" class="btn btn-lg btn-success px-4 py-2 shadow-lg border-0 rounded-pill">
            <i class="fas fa-plus-circle"></i> Create New Log
        </a>
    </div>

    <!-- Bảng dữ liệu -->
    <div class="table-responsive">
        <table class="table table-striped table-hover table-bordered table-sm">
            <thead class="thead-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Lab)</th>
                    <th>@Html.DisplayNameFor(model => model.User)</th>
                    <th>@Html.DisplayNameFor(model => model.Purpose)</th>
                    <th>@Html.DisplayNameFor(model => model.StartTime)</th>
                    <th>@Html.DisplayNameFor(model => model.EndTime)</th>
                    <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.Lab.LabName)</td>
                        <td>@Html.DisplayFor(modelItem => item.User.FullName)</td>
                        <td>@Html.DisplayFor(modelItem => item.Purpose)</td>
                        <td>@Html.DisplayFor(modelItem => item.StartTime)</td>
                        <td>@Html.DisplayFor(modelItem => item.EndTime)</td>
                        <td>@Html.DisplayFor(modelItem => item.CreatedAt)</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm rounded-pill shadow-sm">
                                <i class="fas fa-edit"></i> Edit
                            </a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm rounded-pill shadow-sm">
                                <i class="fas fa-info-circle"></i> Details
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm rounded-pill shadow-sm" onclick="return confirm('Are you sure you want to delete this log?');">
                                <i class="fas fa-trash-alt"></i> Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

   
</div>
