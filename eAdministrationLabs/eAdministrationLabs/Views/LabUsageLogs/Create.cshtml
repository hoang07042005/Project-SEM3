@model eAdministrationLabs.Models.ViewModels.CreateLabUsageLogViewModel

@{
    ViewData["Title"] = "Create";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1 class="text-center my-5 font-weight-bold text-dark">CREATE LAB USAGE LOG</h1>


<hr class="my-4" />

<div class="row justify-content-center">
    <div class="col-md-10 col-lg-8">
        <form asp-action="Create" class="p-4 bg-white shadow-sm rounded-lg">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <!-- Row 1 - Lab and User -->
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="CreateLabUsageLogDto.LabId" class="control-label font-weight-semibold text-dark text-uppercase">LAB</label>
                    <select asp-for="CreateLabUsageLogDto.LabId" class="form-control form-control-lg border-dark">
                        <option value="">Select a Lab</option>
                        @foreach (var lab in Model.Labs)
                        {
                            <option value="@lab.Value">@lab.Text</option>
                        }
                    </select>
                    <span asp-validation-for="CreateLabUsageLogDto.LabId" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CreateLabUsageLogDto.UserId" class="control-label font-weight-semibold text-dark text-uppercase">USER</label>
                    <select asp-for="CreateLabUsageLogDto.UserId" class="form-control form-control-lg border-dark">
                        <option value="">Select a User</option>
                        @foreach (var user in Model.Users)
                        {
                            <option value="@user.Value">@user.Text</option>
                        }
                    </select>
                    <span asp-validation-for="CreateLabUsageLogDto.UserId" class="text-danger"></span>
                </div>
            </div>

            <!-- Row 2 - Purpose, Start Time, and End Time -->
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label asp-for="CreateLabUsageLogDto.Purpose" class="control-label font-weight-semibold text-dark text-uppercase">PURPOSE</label>
                    <input asp-for="CreateLabUsageLogDto.Purpose" class="form-control form-control-lg border-dark" placeholder="Enter purpose for lab usage" />
                    <span asp-validation-for="CreateLabUsageLogDto.Purpose" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CreateLabUsageLogDto.StartTime" class="control-label font-weight-semibold text-dark text-uppercase">START TIME</label>
                    <input asp-for="CreateLabUsageLogDto.StartTime" class="form-control form-control-lg border-dark" type="datetime-local" />
                    <span asp-validation-for="CreateLabUsageLogDto.StartTime" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="CreateLabUsageLogDto.EndTime" class="control-label font-weight-semibold text-dark text-uppercase">END TIME</label>
                    <input asp-for="CreateLabUsageLogDto.EndTime" class="form-control form-control-lg border-dark" type="datetime-local" />
                    <span asp-validation-for="CreateLabUsageLogDto.EndTime" class="text-danger"></span>
                </div>
            </div>

            <!-- Submit Button -->
            <div class="form-group text-center">
                <input type="submit" value="CREATE" class="btn btn-dark btn-lg w-50" />
            </div>
        </form>
    </div>
</div>

<!-- Back Button -->
<div class="text-center mt-4">
    <a asp-action="Index" class="btn btn-outline-dark btn-lg">BACK TO LIST</a>
</div>
